<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>HTML Tags</title>

    <style>
        body {
            font-family: Arial;
            background: linear-gradient(to right, #74ebd5, #ACB6E5);
            margin: 0;
        }

        header, footer {
            background-color: #2c3e50;
            color: white;
            text-align: center;
            padding: 15px;
        }

        section {
            background-color: white;
            margin: 20px;
            padding: 20px;
            border-radius: 10px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid black;
            padding: 8px;
            text-align: center;
        }

        button {
            padding: 10px;
            background-color: #3498db;
            color: white;
            border: none;
        }
    </style>
</head>

<body>

<header>
    <h1>HTML Formatted Tags </h1>
    <p><em>Full Stack Development Assignment</em></p>
</header>

<section>
    <h2>Text Formatting Tags</h2>
    <p>This is <b>Bold</b><br><br>
	 <i>Italic</i><br><br> 
	<u>Underline</u><br><br> 
    <strong>Strong</strong><br><br> 
	 <em>Emphasized</em><br><br> 
    <mark>Highlighted</mark><br><br> 
 <small>Small</small> text.</p><br><br> 

    <p>H<sub>2</sub>O <br><br> 
	10<sup>2</sup> examples.</p><br><br> 
    <p><del>Deleted Text</del> <br><br>  <ins>Inserted Text</ins></p>
</section>

<section>
    <h2>Lists</h2>
    <h3>Ordered List</h3>
    <ol>
        <li>HTML</li>
        <li>CSS</li>
        <li>JavaScript</li>
    </ol>

    <h3>Unordered List</h3>
    <ul>
        <li>Frontend</li>
        <li>Backend</li>
        <li>Database</li>
    </ul>

    <h3>Description List</h3>
    <dl>
        <dt>HTML</dt>
        <dd>Structure of webpage</dd>
        <dt>CSS</dt>
        <dd>Styling of webpage</dd>
    </dl>
</section>

<section>
    <h2>Image and Hyperlink</h2>
    <img src="https://via.placeholder.com/150" alt="Sample Image">
    <p>Visit <a href="https://www.google.com" target="_blank">Google</a></p>
</section>

<section>
    <h2>Table</h2>
    <table>
        <tr>
            <th>Name</th>
            <th>Course</th>
            <th>Year</th>
        </tr>
        <tr>
            <td>Ammupriya</td>
            <td>MCA</td>
            <td>2026</td>
        </tr>
 <tr>
            <td>Ammu</td>
            <td>MCA</td>
            <td>2026</td>
        </tr>
 <tr>
            <td>Karthi</td>
            <td>MCA</td>
            <td>2026</td>
        </tr>


    </table>
</section>

<section>
    <h2>Form Elements</h2>
    <form>
        <label>Name:</label>
        <input type="text"><br><br>

        <label>Email:</label>
        <input type="email"><br><br>

        <label>Password:</label>
        <input type="password"><br><br>

        <label>Gender:</label>
        <input type="radio" name="gender"> Female
        <input type="radio" name="gender"> Male<br><br>

        <label>Skills:</label>
        <input type="checkbox"> HTML
        <input type="checkbox"> CSS
        <input type="checkbox"> JS<br><br>

        <button type="submit">Submit</button>
    </form>
</section>

<footer>
    <p>&copy; 2026 MCA Assignment</p>
</footer>

</body>
</html>
